---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Nextstep Engineering Software Solutions | Bangkok, Thailand",
  description = "Nextstep delivers scalable software, cloud solutions, and engineering excellence from Bangkok, Thailand. Founded on German engineering standards with a global reach.",
  image = "/hero.webp",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Nextstep Engineering Software Solutions" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />

    <!-- JSON-LD Organization -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Nextstep Engineering Software Solutions Co., Ltd.",
        "url": "https://nextstep.engineer",
        "logo": "https://nextstep.engineer/logo-nextstep.svg",
        "description": "Scalable software and cloud solutions built on German engineering standards, serving clients worldwide from Bangkok, Thailand.",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "689 Sukhumvit Rd, Bhiraj Tower at EmQuartier",
          "addressLocality": "Bangkok",
          "postalCode": "10110",
          "addressCountry": "TH"
        },
        "sameAs": [
          "https://www.linkedin.com/company/nextstep-engineering-software-solutions-co-ltd/"
        ]
      }
    </script>
  </head>
  <body>
    <Navbar
      logoSrc="/logo-nextstep.svg"
      ctaHref="/#contact"
      ctaLabel="Start Your Nextstep"
      links={[
        { href: "/#services", label: "Services" },
        { href: "/#about", label: "About" },
        { href: "/#contact", label: "Contact" },
        // { href: "/insights", label: "Insights" },
        // { href: "/careers", label: "Careers" },
      ]}
    />
    <slot />
    <Footer />
    <div id="cookie-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9998;"></div>
    <div id="cookie-banner" style="position:fixed;bottom:0;left:0;right:0;background:#151824;border-top:1px solid rgba(201,166,70,0.3);color:#fff;padding:15px;font-size:14px;display:flex;justify-content:space-between;align-items:center;z-index:9999;">
      <span>
        This website uses strictly necessary cookies provided by Cloudflare to ensure security and proper performance.
        <a href="/privacy-policy" style="color:#C9A646;">Learn more</a>
      </span>
      <button style="background:#C9A646;border:none;color:#fff;padding:8px 14px;cursor:pointer;border-radius:4px;margin-left:16px;font-weight:500;">
        OK
      </button>
    </div>
    <script>
      const banner = document.getElementById("cookie-banner");
      const overlay = document.getElementById("cookie-overlay");
      let accepted = false;
      try { accepted = !!localStorage.getItem("cookieNotice"); } catch (_) {}
      if (accepted) {
        banner?.remove();
        overlay?.remove();
      } else {
        document.body.style.overflow = "hidden";
        banner?.querySelector("button")?.addEventListener("click", () => {
          try { localStorage.setItem("cookieNotice", "true"); } catch (_) {}
          document.body.style.overflow = "";
          banner?.remove();
          overlay?.remove();
        });
      }
    </script>
  </body>
</html>

<style>
  html {
    margin: 0;
    width: 100%;
    height: 100%;
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
  }

  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
