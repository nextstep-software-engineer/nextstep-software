---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Nextstep Software - Engineering Excellence</title>
  </head>
  <body>
    <Navbar
      logoSrc="/logo-nextstep.svg"
      ctaHref="/#contact"
      ctaLabel="Start Your Nextstep"
      links={[
        { href: "/#services", label: "Services" },
        { href: "/#about", label: "About" },
        { href: "/#contact", label: "Contact" },
        // { href: "/insights", label: "Insights" },
        // { href: "/careers", label: "Careers" },
      ]}
    />
    <slot />
    <Footer />
    <div id="cookie-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:9998;"></div>
    <div id="cookie-banner" style="position:fixed;bottom:0;left:0;right:0;background:#151824;border-top:1px solid rgba(201,166,70,0.3);color:#fff;padding:15px;font-size:14px;display:flex;justify-content:space-between;align-items:center;z-index:9999;">
      <span>
        This website uses strictly necessary cookies provided by Cloudflare to ensure security and proper performance.
        <a href="/privacy-policy" style="color:#C9A646;">Learn more</a>
      </span>
      <button style="background:#C9A646;border:none;color:#fff;padding:8px 14px;cursor:pointer;border-radius:4px;margin-left:16px;font-weight:500;">
        OK
      </button>
    </div>
    <script>
      const banner = document.getElementById("cookie-banner");
      const overlay = document.getElementById("cookie-overlay");
      let accepted = false;
      try { accepted = !!localStorage.getItem("cookieNotice"); } catch (_) {}
      if (accepted) {
        banner?.remove();
        overlay?.remove();
      } else {
        document.body.style.overflow = "hidden";
        banner?.querySelector("button")?.addEventListener("click", () => {
          try { localStorage.setItem("cookieNotice", "true"); } catch (_) {}
          document.body.style.overflow = "";
          banner?.remove();
          overlay?.remove();
        });
      }
    </script>
  </body>
</html>

<style>
  html {
    margin: 0;
    width: 100%;
    height: 100%;
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
  }

  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
