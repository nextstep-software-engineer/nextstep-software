---
// Trust Bar — logo strip of platforms/partners we build on, directly on the
// section background (matching the mockup — no card/pill wrapper).
---

<section class="py-10 sm:py-12 bg-white">
  <div class="max-w-[1440px] px-5 sm:px-8 lg:px-[52px] mx-auto w-full">
    <p class="text-center !text-[12.6px] tracking-[0.15em] text-[#2563EB] uppercase font-semibold mb-8">
      Trusted by Innovative Organizations Worldwide
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-14">
      <img src="/icons-iconify/microsoft.svg" alt="Microsoft" class="h-6 sm:h-7 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <img src="/icons-iconify/aws.svg" alt="AWS" class="h-7 sm:h-8 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <img src="/icons-iconify/azure.svg" alt="Microsoft Azure" class="h-8 sm:h-9 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <span class="inline-flex items-center gap-2 opacity-90 hover:opacity-100 transition-opacity">
        <img src="/icons-iconify/google-cloud-icon.svg" alt="" class="h-6 sm:h-7 w-auto" />
        <span class="!text-[17.5px] font-medium text-[#5F6368]">Google Cloud</span>
      </span>
      <img src="/icons-iconify/sap.svg" alt="SAP" class="h-7 sm:h-8 w-auto opacity-90 hover:opacity-100 transition-opacity" />

      <!-- Siemens — no logo asset exists for this one, so it's styled text -->
      <span class="!text-[19px] font-semibold tracking-wide text-[#009999] opacity-90 hover:opacity-100 transition-opacity">
        SIEMENS
      </span>
    </div>
  </div>
</section>
