---
// Trust Bar — logo strip of platforms/partners we build on, directly on the
// section background (matching the mockup — no card/pill wrapper).
---

<section class="py-10 sm:py-12 bg-[#F9FBFE]">
  <div class="max-w-screen-2xl px-6 sm:px-10 lg:px-16 xl:px-20 mx-auto w-full">
    <p class="text-center !text-[12.6px] tracking-[0.15em] text-[#2563EB] uppercase font-semibold mb-8">
      Trusted by Innovative Organizations Worldwide
    </p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-14">
      <img src="/middle-section-svg/logos_microsoft.svg" alt="Microsoft" class="h-6 sm:h-7 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <img src="/middle-section-svg/logos_aws.svg" alt="AWS" class="h-9 sm:h-10 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <img src="/tech-svg/azure.svg" alt="Microsoft Azure" class="h-7 sm:h-8 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <img src="/middle-section-svg/logos_google.svg" alt="Google Cloud" class="h-6 sm:h-7 w-auto opacity-90 hover:opacity-100 transition-opacity" />
      <img src="/middle-section-svg/logos_sap.svg" alt="SAP" class="h-9 sm:h-10 w-auto opacity-90 hover:opacity-100 transition-opacity" />

      <!-- Siemens — no logo asset exists for this one, so it's styled text -->
      <span class="!text-[19px] font-semibold tracking-wide text-[#009999] opacity-90 hover:opacity-100 transition-opacity">
        SIEMENS
      </span>
    </div>
  </div>
</section>
