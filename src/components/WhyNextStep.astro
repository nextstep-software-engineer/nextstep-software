---

<section class="relative py-16 sm:py-20 lg:py-24 bg-white overflow-hidden">
  <!-- Background photo layer: bleeds to the right/top/bottom edges and fades
       into the white bg on its left side, like the mockup. -->
  <div
    class="absolute inset-y-0 right-0 w-full lg:w-[40%] bg-cover bg-center hidden lg:block"
    style="background-image: linear-gradient(to right, #ffffff 0%, rgba(255,255,255,0.7) 15%, rgba(255,255,255,0) 40%), url('/why-nextstep-team.webp');"
  >
  </div>

  <div class="relative z-10 max-w-screen-2xl px-4 sm:px-6 lg:px-8 mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 lg:gap-16 items-center">
      <!-- Left: heading + icon grid -->
      <div>
        <div class="mb-12 sm:mb-16">
          <h2 class="!text-[24.5px] text-black">Why NextStep</h2>
          <p class="mt-4 !text-[15.4px] text-[#5A5A5A]">
            We combine engineering excellence with business focus to deliver
            measurable results.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-8 gap-y-10">
          {
            reasons.map((reason) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 flex items-center justify-center text-[#2563EB]">
                  {reason.target ? (
                    <svg viewBox="0 0 24 24" fill="none" class="w-7 h-7">
                      <circle
                        cx="12"
                        cy="12"
                        r="8.25"
                        stroke="currentColor"
                        stroke-width="1.5"
                      />
                      <circle
                        cx="12"
                        cy="12"
                        r="4.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                      />
                      <circle cx="12" cy="12" r="1.25" fill="currentColor" />
                    </svg>
                  ) : (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      class="w-7 h-7"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d={reason.path}
                      />
                    </svg>
                  )}
                </div>
                <div>
                  <h3 class="!text-[16.1px] text-black">{reason.title}</h3>
                  <p class="mt-1.5 !text-[13px] text-[#5A5A5A] leading-relaxed">
                    {reason.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right column stays empty on top; the photo lives in the absolute
           layer behind, matching the mockup's edge-to-edge bleed -->
      <div class="hidden lg:block" aria-hidden="true"></div>
    </div>
  </div>
</section>
