<section class="py-10 sm:py-12 bg-[#151824]">
  <div class="max-w-screen-2xl px-6 sm:px-10 lg:px-16 xl:px-20 mx-auto w-full">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-y-8 lg:divide-x lg:divide-white/10">
      {
        stats.map((stat) => (
          <div class="flex flex-col items-center text-center gap-2 px-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d={stat.path} />
            </svg>
            <div class="!text-[28px] sm:!text-[33.6px] font-semibold text-[#4C8DFF] leading-none">
              {stat.value}
            </div>
            <div class="!text-[13px] text-white">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
