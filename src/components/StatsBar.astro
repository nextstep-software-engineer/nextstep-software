---
// Stats Bar — dark navy strip with headline company numbers
// Icons: Tabler Icons (MIT) via the Iconify API — see README.md for credits.
const stats = [
  {
    value: "500+",
    label: "Projects Delivered",
    paths: [
      "M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3-5a9 9 0 0 0 6-8a3 3 0 0 0-3-3a9 9 0 0 0-8 6a6 6 0 0 0-5 3",
      "M7 14a6 6 0 0 0-3 6a6 6 0 0 0 6-3m4-8a1 1 0 1 0 2 0a1 1 0 1 0-2 0",
    ],
  },
  {
    value: "250+",
    label: "Technical Experts",
    paths: [
      "M10 13a2 2 0 1 0 4 0a2 2 0 0 0-4 0m-2 8v-1a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v1M15 5a2 2 0 1 0 4 0a2 2 0 0 0-4 0m2 5h2a2 2 0 0 1 2 2v1M5 5a2 2 0 1 0 4 0a2 2 0 0 0-4 0m-2 8v-1a2 2 0 0 1 2-2h2",
    ],
  },
  {
    value: "20+",
    label: "Countries Served",
    paths: [
      "M3 12a9 9 0 1 0 18 0a9 9 0 0 0-18 0m.6-3h16.8M3.6 15h16.8",
      "M11.5 3a17 17 0 0 0 0 18m1-18a17 17 0 0 1 0 18",
    ],
  },
  {
    value: "15+",
    label: "Years of Experience",
    paths: ["M6 9a6 6 0 1 0 12 0A6 6 0 1 0 6 9", "m12 15l3.4 5.89l1.598-3.233l3.598.232l-3.4-5.889M6.802 12l-3.4 5.89L7 17.657l1.598 3.232l3.4-5.889"],
  },
  {
    value: "98%",
    label: "Client Satisfaction",
    paths: [
      "M3 12a9 9 0 1 0 18 0a9 9 0 1 0-18 0m6-2h.01M15 10h.01",
      "M9.5 15a3.5 3.5 0 0 0 5 0",
    ],
  },
];
---

<section class="py-12 sm:py-14 bg-[#151824]">
  <div class="max-w-[1440px] px-5 sm:px-8 lg:px-[52px] mx-auto w-full">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-y-8 lg:divide-x lg:divide-white/10">
      {
        stats.map((stat) => (
          <div class="flex flex-col items-center text-center gap-3 px-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.4" class="w-12 h-12">
              {stat.paths.map((d) => (
                <path stroke-linecap="round" stroke-linejoin="round" d={d} />
              ))}
            </svg>
            <div class="!text-[28px] sm:!text-[33.6px] font-semibold text-[#4C8DFF] leading-none">
              {stat.value}
            </div>
            <div class="!text-[16px] text-white">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
