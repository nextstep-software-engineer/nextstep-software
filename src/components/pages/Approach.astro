---
const steps = [
  ["Business Challenge", "We start by understanding your business, challenges and desired outcomes."],
  ["Discovery & Strategy", "Deep dive into your needs to define a clear strategy and roadmap."],
  ["Solution Design", "We design the right solution architecture aligned with your goals."],
  ["Engineering & Development", "Agile engineering to build robust, scalable and secure solutions."],
  ["Testing & Validation", "Rigorous testing to ensure quality, performance and reliability."],
  ["Deployment & Integration", "Seamless deployment and integration with your ecosystem."],
  ["Continuous Improvement", "Ongoing support and optimization to drive long-term success."],
];
const nextstep = [
  ["Understands Your Business Goals", "We align technology with your business objectives to create real impact."],
  ["Designs Solutions Around Your Processes", "Solutions built to fit your operations, not the other way around."],
  ["Agile, Transparent Delivery", "Iterative delivery with rapid feedback and adaptability."],
  ["Continuous Client Collaboration", "You're involved at every step with full visibility."],
  ["Built-in Quality from Day One", "Quality engineering and testing throughout the lifecycle."],
  ["Ongoing Optimisation & Support", "We stay with you to optimise, enhance and scale."],
];
const traditional = [
  ["Starts with Technology", "Focus on tools and technology before understanding business context."],
  ["Adapts Your Business to Fit the Software", "Forces process changes to match the solution."],
  ["Long, Rigid Development Cycles", "Waterfall approach with limited flexibility."],
  ["Limited Visibility During Delivery", "Infrequent updates and minimal client involvement."],
  ["Testing Happens Near the End", "Quality checks late, leading to rework and delays."],
  ["Engagement Often Ends at Go-Live", "No long-term partnership or continuous improvement."],
];
const pillars = [
  ["Business Driven", "We focus on your business outcomes, not just technology."],
  ["Engineering Excellence", "Deep engineering expertise delivering robust, scalable and secure solutions."],
  ["Modern Technology", "Leveraging cloud, AI, IoT and modern stacks for future-ready solutions."],
  ["Collaborative Partnership", "Transparent communication and collaboration at every stage."],
  ["Measurable Outcomes", "A data-driven approach that delivers measurable business impact."],
  ["Continuous Innovation", "We help you evolve and innovate for long-term competitive advantage."],
];

// Tabler Icons (MIT), available through Iconify:
// https://icon-sets.iconify.design/tabler/
const stepIcons = [
  ["M10 13a2 2 0 1 0 4 0a2 2 0 0 0-4 0m-2 8v-1a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v1M15 5a2 2 0 1 0 4 0a2 2 0 0 0-4 0m2 5h2a2 2 0 0 1 2 2v1M5 5a2 2 0 1 0 4 0a2 2 0 0 0-4 0m-2 8v-1a2 2 0 0 1 2-2h2"],
  ["M3 10a7 7 0 1 0 14 0a7 7 0 1 0-14 0m18 11l-6-6"],
  ["M13.5 6.5l4 4", "M4 20h4l10.5-10.5a2.828 2.828 0 1 0-4-4L4 16v4", "M12.5 7.5l4 4"],
  ["m7 8l-4 4l4 4", "m17 8l4 4l-4 4", "m14 4l-4 16"],
  ["M12 3l8 4v5c0 5-3.5 7.5-8 9c-4.5-1.5-8-4-8-9V7l8-4", "m9 12l2 2l4-4"],
  ["M7 18a4.6 4.4 0 0 1 0-9a5 4.5 0 0 1 9.7 1.4A4 4 0 0 1 17 18H7", "M12 12v9", "m9 15l3-3l3 3"],
  ["m3 17l6-6l4 4l8-8", "M14 7h7v7"],
];
const pillarIcons = [
  ["M11 12a1 1 0 1 0 2 0a1 1 0 1 0-2 0", "M12 7a5 5 0 1 0 5 5", "M13 3.055A9 9 0 1 0 20.941 11", "M15 6v3h3l3-3h-3V3zm0 3l-3 3"],
  ["M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573c-.94-1.543.826-3.31 2.37-2.37c1 .608 2.296.07 2.572-1.065", "M9 12a3 3 0 1 0 6 0a3 3 0 0 0-6 0"],
  ["M6.657 18C4.085 18 2 15.993 2 13.517s2.085-4.482 4.657-4.482c.393-1.762 1.794-3.2 3.675-3.773c1.88-.572 3.956-.193 5.444 1c1.488 1.19 2.162 3.007 1.77 4.769h.99c1.913 0 3.464 1.56 3.464 3.486s-1.551 3.487-3.465 3.487H6.657"],
  ["M10 13a2 2 0 1 0 4 0a2 2 0 0 0-4 0m-2 8v-1a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v1M15 5a2 2 0 1 0 4 0a2 2 0 0 0-4 0m2 5h2a2 2 0 0 1 2 2v1M5 5a2 2 0 1 0 4 0a2 2 0 0 0-4 0m-2 8v-1a2 2 0 0 1 2-2h2"],
  ["M4 19v-6M8 19V9M12 19v-4M16 19V5M20 19V2", "M3 19h18"],
  ["M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3-5a9 9 0 0 0 6-8a3 3 0 0 0-3-3a9 9 0 0 0-8 6a6 6 0 0 0-5 3", "M7 14a6 6 0 0 0-3 6a6 6 0 0 0 6-3m4-8a1 1 0 1 0 2 0a1 1 0 1 0-2 0"],
];
const comparisonIcons = [
  pillarIcons[0], // business goals — target
  stepIcons[2], // solution design — edit
  ["M20 11A8.1 8.1 0 0 0 4.5 9", "M4 5v4h4", "M4 13a8.1 8.1 0 0 0 15.5 2", "M20 19v-4h-4"], // agile delivery — refresh
  pillarIcons[3], // client collaboration — users
  stepIcons[4], // built-in quality — shield check
  stepIcons[6], // optimisation — trending up
];
---

<main class="approach-page">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">Our Approach</p>
        <h1>Our Approach.<br /><span>Your Advantage.</span></h1>
        <div class="accent-line"></div>
        <p class="intro">At NextStep Engineering, we combine engineering expertise, modern technology and a proven delivery methodology to build intelligent solutions that drive measurable outcomes at every stage of your transformation journey.</p>
      </div>
      <div class="hero-art" role="img" aria-label="NextStep engineering capabilities"></div>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <h2>Our Proven Approach</h2><div class="title-line"></div>
      <div class="steps">
        {steps.map(([title, text], index) => (
          <article class:list={["step-card", { featured: index === 3 }]}>
            <span class="step-number">{String(index + 1).padStart(2, "0")}</span>
            <div class="step-icon" aria-hidden="true"><svg viewBox="0 0 24 24">{stepIcons[index].map((d) => <path d={d}></path>)}</svg></div>
            <h3>{title}</h3><p>{text}</p>
            {index < steps.length - 1 && <span class="arrow" aria-hidden="true"></span>}
          </article>
        ))}
      </div>

      <h2 class="comparison-title">NextStep Approach <span>vs</span> Traditional Delivery</h2>
      <div class="comparison">
        <div class="comparison-column good">
          <h3>NextStep Engineering Approach</h3>
          {nextstep.map(([title, text], index) => <div class="comparison-row"><span class="row-icon"><svg viewBox="0 0 24 24" aria-hidden="true">{comparisonIcons[index].map((d) => <path d={d}></path>)}</svg></span><div><strong>{title}</strong><p>{text}</p></div></div>)}
        </div>
        <div class="comparison-middle">
          <div class="versus">VS</div>
          <div class="middle-icons" aria-hidden="true">
            {comparisonIcons.map((paths) => (
              <span><svg viewBox="0 0 24 24">{paths.map((d) => <path d={d}></path>)}</svg></span>
            ))}
          </div>
        </div>
        <div class="comparison-column old">
          <h3>Traditional Delivery Approach</h3>
          {traditional.map(([title, text]) => <div class="comparison-row"><div><strong>{title}</strong><p>{text}</p></div><span class="row-icon">×</span></div>)}
        </div>
      </div>

      <div class="pillars">
        {pillars.map(([title, text], index) => <article class="pillar"><div class="pillar-icon" aria-hidden="true"><svg viewBox="0 0 24 24">{pillarIcons[index].map((d) => <path d={d}></path>)}</svg></div><div><h3>{title}</h3><p>{text}</p></div></article>)}
      </div>
    </div>
  </section>
</main>

<style>
  .approach-page{color:#08144f;background:#f9fbfe}.hero{background:#000714;color:#fff;overflow:hidden}.hero-inner{max-width:1536px;margin:auto;min-height:350px;display:grid;grid-template-columns:.78fr 1.22fr;align-items:center;padding:24px 5vw 20px}.hero-copy{position:relative;z-index:2;max-width:560px}.eyebrow{margin:0 0 12px;color:#14a5ff;text-transform:uppercase;letter-spacing:.08em;font-weight:600;font-size:13px}h1{margin:0;font-size:clamp(38px,4vw,58px);line-height:1.08;color:#fff}h1 span{background:linear-gradient(90deg,#4b62ff,#16a5f4);background-clip:text;color:transparent}.accent-line{width:40px;height:2px;background:#39a8ff;margin:20px 0 14px}.intro{max-width:545px;margin:0;color:#fffffff0;font-size:15px;line-height:1.75}.hero-art{width:120%;height:100%;min-height:310px;margin-left:-10%;background:url('/approach-hero-banner.webp') center/contain no-repeat}.content-section{padding:14px 0 36px;background:radial-gradient(circle at 50% 0,#fff 0,#f9fbfe 65%)}.container{width:min(1400px,calc(100% - 40px));margin:auto}h2{margin:0;text-align:center;font-size:27px;color:#07145d}.title-line{width:60px;height:2px;margin:5px auto 12px;background:#2164ff}.steps{display:grid;grid-template-columns:repeat(7,1fr);gap:22px}.step-card{position:relative;min-height:194px;padding:12px;text-align:center;border:1px solid #edf1f8;border-radius:10px;background:#ffffffd1;box-shadow:0 6px 24px #102c640d}.step-card.featured{border-color:#2164ff}.step-number{color:#075dff;font-size:13px;font-weight:700}.step-icon{display:grid;place-items:center;width:48px;height:48px;margin:5px auto 7px;border-radius:50%;background:#edf3ff;color:#1029a5}.step-icon svg{width:29px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}.step-card h3,.pillar h3{margin:0 0 6px;font-family:Inter,sans-serif;font-size:14px}.step-card p,.pillar p{margin:0;color:#18204a;font-size:12px;line-height:1.55}.arrow{position:absolute;z-index:3;top:53px;left:calc(100% + 4px);width:14px;height:8px;border-top:2px dotted #0865ff}.arrow::after{content:"";position:absolute;top:-4px;right:0;width:6px;height:6px;border-top:2px solid #0865ff;border-right:2px solid #0865ff;transform:rotate(45deg)}.comparison-title{margin-top:16px;font-size:27px}.comparison-title span{color:#1265ff}.comparison{display:grid;grid-template-columns:1fr 54px 1fr;align-items:stretch;width:min(1250px,100%);margin:9px auto 20px}.comparison-column{overflow:hidden;border-radius:11px;background:#ffffffe6;box-shadow:0 5px 22px #102c640f}.comparison-column>h3{margin:0;padding:9px 14px;text-align:center;font-size:16px;color:#fff;background:linear-gradient(90deg,#132d93,#145dff)}.comparison-column.old>h3{background:linear-gradient(90deg,#333947,#606778)}.comparison-row{min-height:54px;display:grid;grid-template-columns:46px 1fr;gap:8px;align-items:center;padding:6px 16px;border-bottom:1px solid #e7ebf3}.comparison-row:last-child{border-bottom:0}.row-icon{display:grid;place-items:center;width:28px;height:28px;border-radius:50%;color:#fff;background:#10218d;font-weight:700}.good .row-icon{color:#075dff;background:transparent;border-radius:0}.good .row-icon svg{width:28px;height:28px;fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}.old .row-icon{justify-self:end;color:#7a849e;background:transparent;border:1px solid #c8cfdb}.comparison-row strong{display:block;font-size:15px;line-height:1.25}.good .comparison-row strong{color:#075dff}.old .comparison-row strong{color:#171d39}.comparison-row p{margin:3px 0 0;font-size:13px;line-height:1.4}.good .comparison-row p{color:#263154}.old .comparison-row p{color:#596176}.versus{align-self:start;justify-self:center;margin-top:-1px;width:36px;height:36px;display:grid;place-items:center;border-radius:50%;border:1px solid #d9e2f3;background:#fff;color:#1232a0;font-size:14px;font-weight:700}.pillars{display:grid;grid-template-columns:repeat(6,1fr);padding:20px;border:1px solid #edf1f7;border-radius:14px;background:#ffffffb8;box-shadow:0 7px 24px #102c640d}.pillar{display:grid;grid-template-columns:58px 1fr;gap:10px;min-height:88px;padding:5px 18px;border-right:1px solid #dfe5ef;align-items:center}.pillar:last-child{border-right:0}.pillar-icon{display:grid;place-items:center;color:#075dff}.pillar-icon svg{width:42px;height:42px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}
  .comparison-middle{display:flex;flex-direction:column;align-items:center}.comparison-middle .versus{flex:0 0 36px}.middle-icons{width:100%}.middle-icons span{height:54px;display:grid;place-items:center}.middle-icons svg{width:32px;height:32px;padding:6px;box-sizing:border-box;border-radius:50%;background:#101d78;color:#fff;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;box-shadow:0 2px 8px #102c6433}
  .comparison-column>h3{height:38px;box-sizing:border-box;display:grid;place-items:center;padding:0 14px}.comparison-middle .versus{align-self:center;margin-top:1px}.middle-icons{margin-top:1px}
  .old .comparison-row{grid-template-columns:1fr 46px}.old .row-icon{justify-self:end}
  .comparison{position:relative;grid-template-columns:1fr 76px 1fr}.comparison::before{content:"";position:absolute;z-index:0;top:18px;left:0;right:0;height:1px;background:#cbd2df}.comparison-column{position:relative;z-index:1}.comparison-middle{position:relative;z-index:2}
  @media(max-width:1320px){.pillars{grid-template-columns:repeat(3,1fr);row-gap:18px}.pillar:nth-child(3){border-right:0}}
  @media(max-width:960px){.comparison{grid-template-columns:1fr;gap:16px;width:min(680px,100%)}.comparison::before,.comparison-middle{display:none}.comparison-column>h3{height:auto;min-height:42px}.comparison-title{max-width:680px;margin-left:auto;margin-right:auto}}
  @media(max-width:1100px){.steps{grid-template-columns:repeat(4,1fr)}.arrow{display:none}.pillars{grid-template-columns:repeat(3,1fr);row-gap:18px}.pillar:nth-child(3){border-right:0}}
  @media(max-width:760px){.hero-inner{grid-template-columns:1fr;padding:45px 24px 20px;text-align:center}.hero-copy{margin:auto}.accent-line{margin-left:auto;margin-right:auto}.hero-art{width:115%;min-height:230px;margin:5px 0 0 -7.5%}.container{width:min(100% - 28px,1400px)}.steps{grid-template-columns:repeat(2,1fr);gap:12px}.comparison{grid-template-columns:1fr;gap:12px}.comparison::before{display:none}.comparison-middle{display:none}.pillars{grid-template-columns:1fr;padding:15px}.pillar,.pillar:nth-child(3){border-right:0;border-bottom:1px solid #dfe5ef;padding:12px 8px}.pillar:last-child{border-bottom:0}}
  @media(max-width:520px){.hero-inner{padding-left:18px;padding-right:18px}.hero-art{min-height:190px}.content-section{padding-top:22px}.container{width:calc(100% - 24px)}h2,.comparison-title{font-size:23px}.steps{grid-template-columns:1fr}.step-card{min-height:0;padding:16px}.comparison-row,.old .comparison-row{grid-template-columns:38px 1fr;padding:9px 10px}.old .comparison-row{grid-template-columns:1fr 38px}.comparison-row strong{font-size:14px}.comparison-row p{font-size:12px}.pillars{padding:10px}.pillar{grid-template-columns:50px 1fr}.pillar-icon svg{width:36px;height:36px}}
</style>
