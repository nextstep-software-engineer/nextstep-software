---

<main class="solutions-page">
  <section class="hero">
    <img src="/solutions-hero.webp" alt="Digital factory platform with an industrial robotic arm" />
    <div class="hero-copy wrap">
      <p class="eyebrow">END-TO-END SOLUTIONS</p>
      <h1>Complete Engineering.<br />Intelligent Solutions.<br /><span>Better Outcomes.</span></h1>
      <p>From concept to continuous improvement, NextStep Engineering delivers complete digital transformation solutions for <b>engineering</b>, <b>industrial</b>, and <b>enterprise</b> businesses.</p>
    </div>
  </section>

  <section class="section wrap">
    <h2>OUR END-TO-END SOLUTIONS</h2>
    <div class="solutions-grid">
      {solutions.map((s) => <article class="solution-card">
        <div class="icon large">{reusedIcons[s.icon] ? <svg viewBox="0 0 24 24" aria-hidden="true">{reusedIcons[s.icon].map(d => <path d={d} />)}</svg> : <img src={`/icons-iconify/solutions/${s.icon}.svg`} alt="" />}</div>
        <div class="card-body"><h3>{s.title}</h3><p>{s.text}</p><ul>{s.items.map(i => <li>{i}</li>)}</ul></div>
        <a href="/contact" aria-label={`Learn more about ${s.title}`}>→</a>
      </article>)}
    </div>
  </section>

  <section class="why section wrap">
    <h2>WHY NEXTSTEP ENGINEERING?</h2>
    <div class="value-grid">{values.map(([icon, title, text]) => <article><div class="icon">{reusedIcons[icon] ? <svg viewBox="0 0 24 24" aria-hidden="true">{reusedIcons[icon].map(d => <path d={d} />)}</svg> : <img src={`/icons-iconify/solutions/${icon}.svg`} alt="" />}</div><div><h3>{title}</h3><p>{text}</p></div></article>)}</div>
  </section>

  <section class="process section wrap">
    <h2>HOW WE WORK</h2>
    <div class="steps">{steps.map(([icon,title,text]) => <article><div class="step-icon">{reusedIcons[icon] ? <svg viewBox="0 0 24 24" aria-hidden="true">{reusedIcons[icon].map(d => <path d={d} />)}</svg> : <img src={`/icons-iconify/solutions/${icon}.svg`} alt="" />}</div><h3>{title}</h3><p>{text}</p></article>)}</div>
  </section>

</main>

<style>
  .icon img{width:42px;height:42px;object-fit:contain}.value-grid .icon img{width:37px;height:37px}.step-icon img{width:30px;height:30px;filter:brightness(0) invert(1)}.cta-gear img{width:95px;height:95px;filter:brightness(0) invert(1)}
  .process{padding-bottom:72px}
  .steps:after{content:"";position:absolute;right:-4px;top:24px;width:8px;height:8px;border-radius:50%;background:#075ddd;z-index:2}
  .solutions-page .process>h2{font-size:19px}.solutions-page .steps h3{font-size:15px}.solutions-page .steps p{font-size:12px;line-height:1.45;max-width:145px}
  @media(max-width:1000px){.steps:after{display:none}.solutions-page .steps{display:flex;overflow-x:auto;gap:12px;padding:4px 2px 18px;scroll-snap-type:x mandatory}.solutions-page .steps article{flex:0 0 150px;scroll-snap-align:start}}
  .solutions-page .solution-card{min-height:365px}.solutions-page .card-body h3{font-size:20.5px}.solutions-page .card-body p{font-size:14px;line-height:1.6}.solutions-page .card-body li{font-size:13.5px}.solutions-page .value-grid h3{font-size:15.5px}.solutions-page .value-grid p{font-size:13.5px;line-height:1.55}
  .solutions-page{background:#fff;color:#071330;overflow:hidden}.wrap{max-width:1440px;margin:0 auto;padding-left:52px;padding-right:52px}.hero{height:475px;position:relative;border-bottom:1px solid #dfe5ef;background:#f7fbff}.hero>img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}.hero-copy{position:relative;z-index:1;padding-top:45px}.eyebrow{font-family:Manrope,sans-serif;color:#0755ca;font-weight:800;letter-spacing:.12em;font-size:18px;margin:0 0 14px}.hero h1{font-size:52px;line-height:1.05;margin:0 0 24px;letter-spacing:-.035em}.hero h1 span{color:#075ddd}.hero-copy>p:last-child{font-size:16px;line-height:1.75;max-width:610px;margin:0}.hero b{color:#075ddd;font-weight:600}.section{padding-top:21px}.section>h2{text-align:center;font-size:18px;letter-spacing:.12em;margin:0 0 20px}.solutions-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px 24px}.solution-card{min-height:350px;border:1px solid #d8dee8;border-radius:8px;padding:26px 20px;display:grid;grid-template-columns:92px 1fr;position:relative;box-shadow:0 2px 8px rgba(13,49,98,.03)}.icon{width:64px;height:64px;border-radius:50%;background:linear-gradient(145deg,#eef4ff,#f8faff);display:grid;place-items:center;color:#075ddd;flex:none}.icon.large{width:78px;height:78px}.icon svg{width:42px;height:42px;fill:none;stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}.card-body h3{font-size:19px;line-height:1.25;margin:2px 0 13px}.card-body p{font-size:12.5px;line-height:1.65;margin:0 0 12px}.card-body ul{padding:0;margin:0;list-style:none}.card-body li{font-size:12.5px;margin:6px 0;padding-left:20px;position:relative}.card-body li:before{content:'✓';position:absolute;left:0;top:0;color:#075ddd;border:1px solid #075ddd;border-radius:50%;font-size:8px;width:11px;height:11px;line-height:10px;text-align:center}.solution-card>a{position:absolute;right:16px;bottom:14px;width:34px;height:34px;border:1px solid #91aee3;color:#075ddd;border-radius:50%;display:grid;place-items:center;text-decoration:none;font-size:22px}.why{padding-top:18px}.why>h2{margin-bottom:14px}.why>h2:after,.process>h2:after{content:'';display:block;width:38px;height:3px;background:#075ddd;margin:7px auto 0}.value-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid #d8dee8;border-radius:8px}.value-grid article{display:flex;gap:16px;padding:20px 22px;min-height:126px}.value-grid article+article{border-left:1px solid #e2e6ed}.value-grid .icon{width:58px;height:58px}.value-grid .icon svg{width:37px;height:37px}.value-grid h3{font-size:14px;margin:2px 0 8px}.value-grid p{font-size:12px;line-height:1.6;margin:0}.process{padding-top:16px}.process>h2{margin-bottom:19px}.steps{display:grid;grid-template-columns:repeat(7,1fr);position:relative}.steps:before{content:'';position:absolute;left:5%;right:0;top:28px;height:2px;background:#1763d9}.steps article{text-align:center;position:relative}.step-icon{position:relative;margin:0 auto 10px;background:#075ddd;color:#fff;width:56px;height:56px;border-radius:50%;display:grid;place-items:center}.step-icon svg{width:30px;height:30px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}.steps h3{font-size:13px;margin:0 0 4px}.steps p{font-size:10.5px;line-height:1.4;margin:0 auto;max-width:130px}.cta{margin-top:18px;margin-bottom:30px;background:linear-gradient(110deg,#061032,#071749 65%,#061238);border-radius:8px;min-height:176px;color:white;display:grid;grid-template-columns:170px 1fr 330px;align-items:center;position:relative}.cta:after{content:'';position:absolute;right:0;inset-block:0;width:230px;background:radial-gradient(circle at 80% 70%,#0b43a7 0 3px,transparent 4px),radial-gradient(circle at 90% 45%,#0b43a7 0 3px,transparent 4px);opacity:.7}.cta-gear{display:grid;place-items:center}.cta-gear svg{width:95px;height:95px;fill:none;stroke:white;stroke-width:1.4;stroke-linecap:round;stroke-linejoin:round}.cta-copy{z-index:1}.cta-copy h2{text-align:left;font-size:25px;margin:0 0 8px}.cta-copy p{font-size:14px;line-height:1.55;margin:0}.cta-actions{display:grid;gap:12px;z-index:1}.cta-actions a{height:48px;border:1px solid #fff;border-radius:4px;color:#fff;text-decoration:none;font-size:14px;display:flex;align-items:center;justify-content:space-between;padding:0 22px}.cta-actions a.primary{border-color:#075ddd;background:#075ddd}.cta-actions span{font-size:25px}
  @media(max-width:1000px){.hero{height:520px}.hero>img{opacity:.48;object-position:62% center}.hero h1{font-size:44px}.solutions-grid{grid-template-columns:repeat(2,1fr)}.value-grid{grid-template-columns:repeat(2,1fr)}.value-grid article:nth-child(3){border-left:0;border-top:1px solid #e2e6ed}.value-grid article:nth-child(4){border-top:1px solid #e2e6ed}.steps{grid-template-columns:repeat(4,1fr);gap:24px 0}.steps:before{display:none}.cta{grid-template-columns:120px 1fr 280px}}
  @media(max-width:680px){.wrap{padding-left:20px;padding-right:20px}.hero{height:580px}.hero>img{opacity:.24;object-position:70% bottom}.hero-copy{padding-top:42px}.eyebrow{font-size:14px}.hero h1{font-size:38px;line-height:1.12}.hero-copy>p:last-child{font-size:15px}.solutions-grid{grid-template-columns:1fr}.solution-card{grid-template-columns:72px 1fr;padding:20px 16px;min-height:0}.icon.large{width:60px;height:60px}.icon.large svg{width:34px;height:34px}.value-grid{grid-template-columns:1fr}.value-grid article+article{border-left:0;border-top:1px solid #e2e6ed}.steps{grid-template-columns:repeat(2,1fr)}.cta{margin-inline:12px;padding:26px 22px;grid-template-columns:1fr;text-align:center}.cta-gear{display:none}.cta-copy h2{text-align:center;font-size:23px}.cta-copy p br{display:none}.cta-actions{margin-top:20px}.section>h2{font-size:16px}}
  @media(max-width:680px){.solutions-page .solution-card{min-height:0}.solutions-page .card-body h3{font-size:19px}.solutions-page .card-body p{font-size:13.5px}.solutions-page .card-body li{font-size:13px}}
</style>
