];

const values = [
  ["users", "Engineering First", "We understand engineering challenges. Our solutions are built for real-world engineering advantage."],
  ["shield-check", "End-to-End Delivery", "From strategy and consulting to implementation and support – we deliver measurable results."],
  ["world", "Global Expertise", "International experience across industries with a local presence and domain knowledge."],
  ["bulb", "Technology Independent", "We recommend the right technology for your business – not tied to any platform or tool."],
