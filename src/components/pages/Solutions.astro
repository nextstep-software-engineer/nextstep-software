  { icon: "cube", title: "Product Lifecycle Management", text: "Managing the complete lifecycle of engineering and product data with structured change, configuration, and document management processes.", items: ["PLM Strategy & Implementation", "Engineering Change Management", "BOM Management", "Configuration Management", "Document Control", "Product Data Governance"] },
  { icon: "laptop", title: "Custom Software & Enterprise Platforms", text: "Software built specifically for unique business needs to drive efficiency and growth.", items: ["Web Applications", "Mobile Applications", "ERP Systems", "APIs", "Enterprise Platforms", "Customer Portals"] },
  { icon: "hierarchy", title: "Enterprise Integration & Business Applications", text: "Connect business systems, automate workflows, and build internal applications that improve operational efficiency and data visibility across the organisation.", items: ["Workflow Automation", "Business Process Applications", "ERP & CRM Integration", "API Integration", "Data Synchronisation", "Reporting & Analytics Dashboards"] },
