<main class="contact-page">
  <section class="hero">
    <img src="/contact-hero.webp" alt="Modern engineering headquarters and city skyline" />
    <div class="hero-copy wrap contact-shell">
      <p class="eyebrow">CONTACT US</p>
      <h1>Let’s build the right<br />software solution for<br /><span>your business.</span></h1>
      <p class="intro">Whether you need a custom application, enterprise platform,<br />cloud migration, system integration, or AI-powered solution,<br />our team is ready to help you plan your next step.</p>
    </div>
  </section>

  <div class="wrap content contact-shell">
    <section class="contact-grid">
      <aside class="panel details">
        <h2>Get in touch</h2>
        <div class="contact-list">
          {contactItems.map(([icon,title,value]) => <div class="contact-item"><span class="round-icon"><img src={`/icons-iconify/contact/${icon}.svg`} alt="" /></span><div>{title !== "Business Email" && <strong>{title}</strong>}{title === "Business Email" ? <a href={`mailto:${value}`}>{value}</a> : title === "Phone" ? <a href="tel:+6620172700">{value}</a> : title === "Location" ? <a href="https://maps.google.com/?q=Nextstep+Engineering+Software+Solutions+Co.+Ltd.+Bangkok" target="_blank" rel="noopener noreferrer">{value}</a> : <p>{value}</p>}</div></div>)}
        </div>
      </aside>

      <section class="panel message">
        <h2>Send us a message</h2>
        <form id="message-form">
          <div class="field-row"><input aria-label="Your full name" name="name" placeholder="Your full name*" required /><input type="email" aria-label="Your business email" name="email" placeholder="Your business email*" required /></div>
          <input aria-label="Company name" name="company" placeholder="Company name" required />
          <input aria-label="Subject" name="subject" placeholder="Subject" required />
          <textarea aria-label="How can we help?" name="message" placeholder="How can we help?*" required></textarea>
          <button type="submit">
            <span class="button-spinner" aria-hidden="true"></span>
            <span class="button-label">Send Message</span>
            <span class="button-arrow" aria-hidden="true">→</span>
          </button>
          <div id="form-notice" class="form-notice" role="status" aria-live="polite" hidden>
            <span class="form-notice-icon" aria-hidden="true"></span>
            <div>
              <strong class="form-notice-title"></strong>
              <p class="form-notice-message"></p>
            </div>
          </div>
        </form>
      </section>
    </section>

    <section class="trust-strip">
      {trustItems.map(([icon,title,text]) => <article><span class="trust-icon"><img src={icon === "shield" || icon === "users" ? `/icons-iconify/solutions/${icon === "shield" ? "shield-check" : "users"}.svg` : `/icons-iconify/contact/${icon}.svg`} alt="" /></span><div><h3>{title}</h3><p>{text}</p></div></article>)}
    </section>

    <section class="closing">
      <div class="closing-left">
        <h2>A simple conversation can save<br />months of development time.</h2><span class="line"></span>
        <p>We focus on understanding your business first, then designing<br />software that is practical, scalable, and aligned with your<br />operational goals. If we’re not the right fit, we’ll tell you honestly<br />and point you in the right direction.</p>
        <div class="metrics">
          <div><img src="/icons-iconify/solutions/users.svg" alt="" /><strong>100+<small>Projects Delivered</small></strong></div>
          <div><img src="/icons-iconify/solutions/world.svg" alt="" /><strong>20+<small>Industries Served</small></strong></div>
          <div><img src="/icons-iconify/contact/handshake.svg" alt="" /><strong>Long-term<small>Partnerships</small></strong></div>
        </div>
      </div>
      <blockquote class="final-quote">
        <span class="quote" aria-hidden="true">“</span>
        <p>We don’t just build software — we build practical solutions that create measurable business value. <strong>Let’s take the next step together.</strong></p>
      </blockquote>
    </section>
  </div>
</main>

<!-- Web3Forms integration: remove this script and restore the button's previous
     type/onclick attributes above to revert the contact-form connection. -->
<script>
  const form = document.querySelector<HTMLFormElement>("#message-form");
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');
  const submitLabel = submitBtn?.querySelector<HTMLElement>(".button-label");
  const notice = form?.querySelector<HTMLElement>("#form-notice");
  const noticeTitle = notice?.querySelector<HTMLElement>(".form-notice-title");
  const noticeMessage = notice?.querySelector<HTMLElement>(".form-notice-message");
  const requiredFields = form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
    "input[required], textarea[required]",
  );

  requiredFields?.forEach((field) => {
    const validate = () => {
      field.setCustomValidity(field.value.trim() ? "" : "Please complete this field.");
    };
    field.addEventListener("input", validate);
    field.addEventListener("change", validate);
  });

  const showNotice = (type: "success" | "error", title: string, message: string) => {
    if (!notice || !noticeTitle || !noticeMessage) return;
    notice.className = `form-notice ${type}`;
    noticeTitle.textContent = title;
    noticeMessage.textContent = message;
    notice.hidden = false;
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!submitBtn) return;

    requiredFields?.forEach((field) => {
      field.setCustomValidity(field.value.trim() ? "" : "Please complete this field.");
    });
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (notice) notice.hidden = true;
    const formData = new FormData(form);
    formData.append("access_key", "ff64ee9c-4f58-4300-8b3e-db7567f72668");
    formData.append("from_name", "NextStep Website");

    submitBtn.classList.add("is-loading");
    submitBtn.setAttribute("aria-busy", "true");
    if (submitLabel) submitLabel.textContent = "Sending message…";
    submitBtn.disabled = true;

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData,
      });
      const data = await response.json();

      if (response.ok && data.success) {
        form.reset();
        showNotice(
          "success",
          "Message sent successfully",
          "Thank you for contacting NextStep. Our team will respond within one business day.",
        );
      } else {
        showNotice(
          "error",
          "We couldn’t send your message",
          data.message || "Please check your details and try again.",
        );
      }
    } catch {
      showNotice(
        "error",
        "Connection problem",
        "Please check your internet connection and try again.",
      );
    } finally {
      submitBtn.classList.remove("is-loading");
      submitBtn.removeAttribute("aria-busy");
      if (submitLabel) submitLabel.textContent = "Send Message";
      submitBtn.disabled = false;
    }
  });
</script>

