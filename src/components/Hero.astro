---

---

<section class="relative text-white py-16 sm:py-20 lg:py-24 overflow-hidden">
  <!-- Background photo layer: bleeds to the right/bottom edges and fades into
       the dark navy on its left side, like the mockup. -->
  <div
    class="absolute inset-y-0 right-0 w-full lg:w-[60%] bg-cover bg-top hidden lg:block"
    style="background-image: linear-gradient(to right, #151824 0%, rgba(21,24,36,0.55) 20%, rgba(21,24,36,0) 45%), linear-gradient(to bottom, #151824 0%, rgba(21,24,36,0) 14%), url('/hero-team.webp');"
  >
  </div>

  <div class="relative z-10 max-w-screen-2xl px-4 sm:px-6 lg:px-8 mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left Content -->
      <div class="flex flex-col gap-8 text-center lg:text-left min-w-0">
        <h1 class="!text-[28px] sm:!text-[33px] lg:!text-[39.9px] leading-tight break-words">
          Engineering the Next.<br />Delivering What Matters.
        </h1>

        <p class="!text-[16.1px] text-[#E8E8E8] max-w-2xl mx-auto lg:mx-0">
          We build cloud-native software and DevOps solutions that accelerate
          innovation, improve reliability, and drive business outcomes.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
        >
          <a
            href="/#what-we-do"
            class="inline-flex items-center justify-center gap-2 px-4 py-2 !text-[15.4px] bg-[#2563EB] rounded-[20px] hover:bg-[#1d4fd1] transition-colors"
          >
            Our Services
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-4 py-2 !text-[15.4px] text-white border border-white rounded-[20px] hover:bg-white/10 transition-colors"
          >
            Talk to an Expert
          </a>
        </div>
      </div>

      <!-- Right column stays empty on top; the photo lives in the absolute
           layer behind, matching the mockup's edge-to-edge bleed -->
      <div class="hidden lg:block" aria-hidden="true"></div>
    </div>
  </div>
</section>
