<section id="services" class="scroll-mt-16 pt-4 sm:pt-6 lg:pt-8 pb-16 sm:pb-20 lg:pb-24 bg-white">
  <div class="max-w-screen-2xl px-4 sm:px-6 lg:px-8 mx-auto w-full">
    <div class="mb-10 sm:mb-12">
      <h2 class="!text-[24.5px] text-black">Our Services</h2>
      <p class="mt-4 !text-[15.4px] text-[#5A5A5A]">
        End-to-end engineering solutions to build, modernize, and operate
        scalable software systems.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-6 lg:gap-4">
      {
        services.map((service) => (
          <div class="flex flex-col items-center text-center gap-4 p-6 bg-white border border-[#DBDBDA] rounded-[20px]">
            <div class="bg-[#EAF0FE] rounded-[20px] w-[49px] h-[49px] flex items-center justify-center text-[#2563EB]">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                class="w-6 h-6"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={service.path}
                />
              </svg>
            </div>
            <h3 class="!text-[15.4px] text-black">{service.title}</h3>
            <p class="!text-[12.6px] text-[#5A5A5A] leading-relaxed">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
