---
// Our Approach — two full slide-style sections: the problem (a tangle of
// disconnected artifacts) followed by the solution (Nextstep's connected,
// validated delivery chain).

// --- Traditional diagram: a deliberately tangled cluster of scattered
// artifacts, each connected to a few others at random to read as "spaghetti".
const scatterNodes = [
  { x: 70, y: 40, label: "Work item" },
  { x: 220, y: 25, label: "Spec doc" },
  { x: 360, y: 55, label: "Teams chat" },
  { x: 50, y: 140, label: "Design doc" },
  { x: 210, y: 120, label: "Legacy code" },
  { x: 350, y: 150, label: "Config change" },
  { x: 80, y: 235, label: "Manual test" },
  { x: 230, y: 215, label: "Hotfix" },
  { x: 370, y: 240, label: "Email thread" },
];
const scatterEdges = [
  [0, 4], [1, 6], [2, 3], [0, 7], [5, 1],
  [8, 3], [4, 6], [2, 7], [5, 8], [0, 2],
  [3, 8], [1, 4],
];

// --- Nextstep diagram: a layered mesh, fully connected between adjacent
// layers, with one node highlighted as the point where automated checks
// validate consistency.
const layerSizes = [2, 3, 4, 4, 3];
const layerX = [60, 260, 460, 660, 860];
const meshHeight = 300;
const meshLayers = layerSizes.map((count, li) => {
  const gap = meshHeight / (count + 1);
  return Array.from({ length: count }, (_, i) => ({
    x: layerX[li],
    y: gap * (i + 1),
  }));
});
const meshEdges: { x1: number; y1: number; x2: number; y2: number }[] = [];
for (let li = 0; li < meshLayers.length - 1; li++) {
  for (const a of meshLayers[li]) {
    for (const b of meshLayers[li + 1]) {
      meshEdges.push({ x1: a.x, y1: a.y, x2: b.x, y2: b.y });
    }
  }
}
const highlightNode = meshLayers[3][1];
---

<section id="approach" class="relative py-16 sm:py-20 lg:py-24 bg-[#151824] overflow-hidden">
  <div class="relative z-10 max-w-screen-xl px-4 sm:px-6 lg:px-8 mx-auto w-full">
    <p class="!text-[12.6px] tracking-[0.15em] text-[#8FB3FA] uppercase">
      Our Approach
    </p>
    <h2 class="mt-2 !text-[24.5px] sm:!text-[28px] text-white">
      The Traditional Way
    </h2>
    <p class="mt-2 !text-[15.4px] text-white/70 italic">
      Logically disconnected delivery
    </p>

    <div class="mt-14 sm:mt-16 overflow-x-auto">
      <div class="flex items-center justify-center gap-6 sm:gap-10 min-w-[760px] mx-auto w-fit">
        <!-- Objectives icon -->
        <div class="flex flex-col items-center text-center shrink-0">
          <div class="w-16 h-16 rounded-[20px] bg-[#2563EB]/15 border border-[#2563EB]/40 flex items-center justify-center text-[#8FB3FA]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <h3 class="mt-3 !text-[12px] text-white max-w-[110px]">Objectives & Requirements</h3>
        </div>

        <div class="flex flex-col items-center gap-1 text-white/50 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18m0 0l-4-4m4 4l-4 4M3 12l4-4m-4 4l4 4" />
          </svg>
          <span class="!text-[10px] uppercase tracking-wide">gap</span>
        </div>

        <!-- Tangled artifact cluster -->
        <div class="flex flex-col items-center shrink-0">
          <div class="rounded-[20px] border border-dashed border-white/25 bg-white/[0.04] p-3">
            <svg viewBox="0 0 420 280" class="w-[340px] sm:w-[420px] h-auto">
              {
                scatterEdges.map(([a, b]) => (
                  <line
                    x1={scatterNodes[a].x}
                    y1={scatterNodes[a].y}
                    x2={scatterNodes[b].x}
                    y2={scatterNodes[b].y}
                    stroke="#8FB3FA"
                    stroke-opacity="0.4"
                    stroke-width="1"
                  />
                ))
              }
              {
                scatterNodes.map((n) => (
                  <g>
                    <rect
                      x={n.x - 48}
                      y={n.y - 17}
                      width="96"
                      height="34"
                      rx="8"
                      fill="#232B45"
                      stroke="white"
                      stroke-opacity="0.35"
                    />
                    <text
                      x={n.x}
                      y={n.y + 4}
                      text-anchor="middle"
                      fill="white"
                      fill-opacity="0.9"
                      font-size="10.5"
                    >
                      {n.label}
                    </text>
                  </g>
                ))
              }
            </svg>
          </div>
          <h3 class="mt-3 !text-[12px] text-white">Scattered Tickets & Docs</h3>
        </div>

        <div class="flex flex-col items-center gap-1 text-white/50 shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h18m0 0l-4-4m4 4l-4 4M3 12l4-4m-4 4l4 4" />
          </svg>
          <span class="!text-[10px] uppercase tracking-wide">gap</span>
        </div>

        <!-- Code & deploy icon -->
        <div class="flex flex-col items-center text-center shrink-0">
          <div class="w-16 h-16 rounded-[20px] bg-[#2563EB]/15 border border-[#2563EB]/40 flex items-center justify-center text-[#8FB3FA]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25" />
            </svg>
          </div>
          <h3 class="mt-3 !text-[12px] text-white max-w-[110px]">Code & Deploy</h3>
        </div>
      </div>
    </div>

    <p class="mt-14 sm:mt-16 !text-[13.5px] text-white/70 max-w-2xl mx-auto text-center leading-relaxed">
      The lack of a direct link between these stages leads to cost and time
      overruns — what gets built quietly drifts from what was actually
      needed.
    </p>
  </div>
</section>

<section class="relative py-16 sm:py-20 lg:py-24 bg-[#151824] border-t border-white/10 overflow-hidden">
  <div class="relative z-10 max-w-screen-xl px-4 sm:px-6 lg:px-8 mx-auto w-full">
    <p class="!text-[12.6px] tracking-[0.15em] text-[#8FB3FA] uppercase">
      Our Approach
    </p>
    <h2 class="mt-2 !text-[24.5px] sm:!text-[28px] text-white">
      The Nextstep Way
    </h2>
    <p class="mt-2 !text-[15.4px] text-[#8FB3FA] italic">
      Logically connected delivery
    </p>

    <div class="mt-14 sm:mt-16 overflow-x-auto">
      <svg viewBox="0 0 900 300" class="w-[820px] sm:w-full max-w-[900px] h-auto mx-auto block">
        {
          meshEdges.map((e) => (
            <line
              x1={e.x1}
              y1={e.y1}
              x2={e.x2}
              y2={e.y2}
              stroke="#2563EB"
              stroke-opacity="0.4"
              stroke-width="1"
            />
          ))
        }
        {
          meshLayers.flat().map((n) => (
            <circle
              cx={n.x}
              cy={n.y}
              r={n === highlightNode ? 11 : 7}
              fill={n === highlightNode ? "#2563EB" : "#3B4874"}
              stroke={n === highlightNode ? "#8FB3FA" : "white"}
              stroke-opacity={n === highlightNode ? "1" : "0.5"}
              stroke-width={n === highlightNode ? 2 : 1}
            />
          ))
        }
        <!-- highlight ring -->
        <circle
          cx={highlightNode.x}
          cy={highlightNode.y}
          r="20"
          fill="none"
          stroke="#8FB3FA"
          stroke-opacity="0.6"
          stroke-width="1.5"
          stroke-dasharray="3 4"
        />
        <!-- callout -->
        <line
          x1={highlightNode.x + 18}
          y1={highlightNode.y - 6}
          x2={highlightNode.x + 60}
          y2={highlightNode.y - 40}
          stroke="#8FB3FA"
          stroke-opacity="0.7"
          stroke-width="1"
        />
        <rect
          x={highlightNode.x + 55}
          y={highlightNode.y - 78}
          width="205"
          height="42"
          rx="8"
          fill="#232B45"
          stroke="#8FB3FA"
          stroke-opacity="0.5"
          stroke-dasharray="3 3"
        />
        <text x={highlightNode.x + 65} y={highlightNode.y - 60} fill="#E5EDFF" font-size="11">
          Automated checks validate
        </text>
        <text x={highlightNode.x + 65} y={highlightNode.y - 46} fill="#E5EDFF" font-size="11">
          consistency at every layer
        </text>
      </svg>
    </div>

    <div class="mt-6 grid grid-cols-3 max-w-[900px] mx-auto !text-[11.5px] text-white/60 uppercase tracking-wide text-center">
      <span>Business Objectives</span>
      <span>Architecture, Specs & Automated Checks</span>
      <span>Application Code</span>
    </div>

    <p class="mt-10 sm:mt-12 !text-[13.5px] text-white/70 max-w-2xl mx-auto text-center leading-relaxed">
      Every stage stays traceable to the one before it, so nothing gets lost
      in translation — fewer surprises, faster delivery, systems built to
      scale with the business.
    </p>
  </div>
</section>
