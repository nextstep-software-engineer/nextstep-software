<section id="leadership" class="scroll-mt-16 py-12 sm:py-16 bg-[#F9FBFE]">
  <div class="max-w-[1440px] px-5 sm:px-8 lg:px-[52px] mx-auto w-full">
    <div class="text-center mb-10">
      <h2 class="!text-[28px] sm:!text-[32px] text-[#0B1220]">
        Executive Leadership
      </h2>
      <div class="w-10 h-[3px] bg-[#2563EB] mx-auto mt-1.5"></div>
      <p class="mt-3 !text-[18px] font-semibold text-[#5A5A5A] max-w-xl mx-auto leading-relaxed">
        Experienced executives delivering technical excellence, process improvement, and business growth.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {
        executives.map((exec) => (
          <div class="flex flex-col bg-white border border-[#DBDBDA] rounded-[16px] overflow-hidden">
            <img
              src={exec.photo}
              alt={exec.name}
              class="w-full h-96 object-cover"
              style={`object-position: ${exec.photoPosition};`}
              loading="lazy"
              decoding="async"
            />
            <div class="p-5 flex-1 flex flex-col gap-3">
              <div>
                <h3 class="!text-[29px] text-[#0B1220]">{exec.name}</h3>
                <p class="mt-1 !text-[17px] font-semibold text-[#2563EB] leading-snug">
                  {exec.titles.map((t) => (
                    <>
                      {t}
                      <br />
                    </>
                  ))}
                </p>
                <div class="mt-2 w-8 h-[2px] bg-[#2563EB]" />
              </div>

              <div class="mt-2 flex flex-col gap-3">
                {exec.bio.map((p) => (
                  <p class="!text-[15px] font-medium text-[#374151] leading-relaxed">{p}</p>
                ))}
              </div>

              <div class="mt-auto pt-1">
                <span class="!text-[15px] font-semibold text-[#2563EB] uppercase tracking-wide">
                  Key Expertise
                </span>
                <ul class="mt-2 flex flex-col gap-2">
                  {exec.expertise.map((item) => (
                    <li class="flex items-center gap-2 !text-[14.5px] font-medium text-[#374151]">
                      <svg viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.8" class="w-4 h-4 shrink-0">
                        {expertiseIcons[item].map((d) => (
                          <path stroke-linecap="round" stroke-linejoin="round" d={d} />
                        ))}
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <a
                href={exec.linkedin ?? "#"}
                target={exec.linkedin ? "_blank" : undefined}
                rel={exec.linkedin ? "noopener noreferrer" : undefined}
                class="mt-3 inline-flex items-center justify-center gap-2 px-4 py-2.5 !text-[13px] font-medium text-[#2563EB] border border-[#2563EB]/25 rounded-xl hover:bg-[#2563EB]/5 transition-colors"
              >
                <svg viewBox="0 0 256 256" class="w-4 h-4">
                  <path fill="#0a66c2" d="M218.123 218.127h-37.931v-59.403c0-14.165-.253-32.4-19.728-32.4c-19.756 0-22.779 15.434-22.779 31.369v60.43h-37.93V95.967h36.413v16.694h.51a39.91 39.91 0 0 1 35.928-19.733c38.445 0 45.533 25.288 45.533 58.186zM56.955 79.27c-12.157.002-22.014-9.852-22.016-22.009s9.851-22.014 22.008-22.016c12.157-.003 22.014 9.851 22.016 22.008A22.013 22.013 0 0 1 56.955 79.27m18.966 138.858H37.95V95.967h37.97zM237.033.018H18.89C8.58-.098.125 8.161-.001 18.471v219.053c.122 10.315 8.576 18.582 18.89 18.474h218.144c10.336.128 18.823-8.139 18.966-18.474V18.454c-.147-10.33-8.635-18.588-18.966-18.453" />
                </svg>
                View LinkedIn Profile
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
