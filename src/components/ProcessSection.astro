<section class="py-8 sm:py-10 bg-white">
  <div class="max-w-screen-2xl px-6 sm:px-10 lg:px-16 xl:px-20 mx-auto w-full">
    <p class="text-center !text-[12.6px] tracking-[0.15em] text-[#2563EB] uppercase font-medium mb-8">
      Our Engineering Process
    </p>

    <div class="overflow-x-auto">
      <div class="flex items-start gap-4 sm:gap-2 min-w-[760px] lg:min-w-0 lg:justify-between">
        {
          steps.map((step, i) => (
            <>
              <div class="flex flex-col items-center text-center gap-3 w-[110px] sm:w-[130px] shrink-0">
                <div class="w-14 h-14 rounded-full border border-[#2563EB]/40 flex items-center justify-center text-[#2563EB]">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d={step.path} />
                  </svg>
                </div>
                <h3 class="!text-[14px] text-black">{step.title}</h3>
                <p class="!text-[11.5px] text-[#5A5A5A] leading-relaxed">{step.description}</p>
              </div>

              {i < steps.length - 1 && (
                <div class="flex items-center pt-6 shrink-0 text-[#2563EB]/40 -mx-1 sm:mx-0">
                  <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="2 3" d="M4 12h13m0 0l-4-4m4 4l-4 4" />
                  </svg>
                </div>
              )}
            </>
          ))
        }
