---
// Our Engineering Process — 6-step delivery flow
// Icons: Tabler Icons (MIT) via the Iconify API — see README.md for credits.
const steps = [
  {
    title: "Discover",
    description: "Understand your business needs and challenges.",
    paths: ["M3 10a7 7 0 1 0 14 0a7 7 0 1 0-14 0m18 11l-6-6"],
  },
  {
    title: "Architect",
    description: "Design scalable solutions and architecture.",
    paths: [
      "M14 3v4a1 1 0 0 0 1 1h4",
      "M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2m-8-4v-5m3 5v-1m3 1v-3",
    ],
  },
  {
    title: "Develop",
    description: "Build robust, performant and innovative technologies.",
    paths: ["m7 8l-4 4l4 4m10-8l4 4l-4 4M14 4l-4 16"],
  },
  {
    title: "Test",
    description: "Ensure quality, performance and reliability.",
    paths: [
      "M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2",
      "M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2m0 9l2 2l4-4",
    ],
  },
  {
    title: "Deploy",
    description: "Seamless deployment and integration.",
    paths: [
      "M4 13a8 8 0 0 1 7 7a6 6 0 0 0 3-5a9 9 0 0 0 6-8a3 3 0 0 0-3-3a9 9 0 0 0-8 6a6 6 0 0 0-5 3",
      "M7 14a6 6 0 0 0-3 6a6 6 0 0 0 6-3m4-8a1 1 0 1 0 2 0a1 1 0 1 0-2 0",
    ],
  },
  {
    title: "Support",
    description: "Continuous support and optimization.",
    paths: [
      "M4 14v-3a8 8 0 1 1 16 0v3m-2 5c0 1.657-2.686 3-6 3",
      "M4 14a2 2 0 0 1 2-2h1a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2zm11 0a2 2 0 0 1 2-2h1a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2z",
    ],
  },
];
---

<section class="py-8 sm:py-10 bg-[#F9FBFE]">
  <div class="max-w-screen-2xl px-6 sm:px-10 lg:px-16 xl:px-20 mx-auto w-full">
    <p class="text-center !text-[12.6px] tracking-[0.15em] text-[#2563EB] uppercase font-medium mb-8">
      Our Engineering Process
    </p>

    <div class="overflow-x-auto">
      <div class="flex items-start min-w-[1350px] lg:min-w-0">
        {
          steps.map((step, i) => (
            <>
              <div class="flex flex-col items-center text-center gap-3 w-[165px] shrink-0">
                <div class="w-20 h-20 rounded-full border border-[#2563EB]/[0.08] flex items-center justify-center text-[#2563EB]">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="w-12 h-12">
                    {step.paths.map((d) => (
                      <path stroke-linecap="round" stroke-linejoin="round" d={d} />
                    ))}
                  </svg>
                </div>
                <h3 class="!text-[16px] text-black">{step.title}</h3>
                <p class="!text-[12px] text-[#5A5A5A] leading-relaxed">{step.description}</p>
              </div>

              {i < steps.length - 1 && (
                <div class="flex items-center flex-1 min-w-[24px] pt-10 px-1 text-[#2563EB]">
                  <div class="flex-1 border-t-2 border-dashed border-current"></div>
                  <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 -ml-1 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 6l6 6l-6 6" />
                  </svg>
                </div>
              )}
            </>
          ))
        }
      </div>
    </div>
  </div>
</section>
