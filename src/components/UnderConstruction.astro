---
// Shared "coming soon" content: hand-built illustration (barrier + cone +
// gear accents), heading, and a button back to Home. Used by the actual
// 404 page and by placeholder routes (Solutions, Approach) for sections
// that don't have real content yet.
interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = "Under construction.. stay tuned.",
  subheading = "NextStep is coming soon.",
} = Astro.props;

const accent = "#2563EB";
---

<section class="flex min-h-[calc(100vh-96px)] items-center justify-center px-4 antialiased overflow-hidden bg-[#F9FBFE]">
  <div class="w-full max-w-2xl text-center">
    <!-- Hand-built "under construction" illustration: barrier board + cone -->
    <svg viewBox="0 0 300 220" class="mx-auto mb-10 w-full max-w-[260px] h-auto" aria-hidden="true">
      <ellipse cx="150" cy="204" rx="110" ry="10" fill="#0B1220" opacity="0.06" />

      <!-- barrier + cone gently float together -->
      <g class="float-group">
        <!-- barrier board -->
        <g>
          <clipPath id="boardClip">
            <rect x="62" y="88" width="176" height="40" rx="6" />
          </clipPath>
          <rect x="62" y="88" width="176" height="40" rx="6" fill="#fff" stroke={accent} stroke-width="2.5" />
          <g clip-path="url(#boardClip)">
            <g stroke="#F59E0B" stroke-width="12">
              <line x1="50" y1="146" x2="96" y2="76" />
              <line x1="82" y1="146" x2="128" y2="76" />
              <line x1="114" y1="146" x2="160" y2="76" />
              <line x1="146" y1="146" x2="192" y2="76" />
              <line x1="178" y1="146" x2="224" y2="76" />
              <line x1="210" y1="146" x2="256" y2="76" />
            </g>
          </g>
        </g>
        <line x1="92" y1="128" x2="86" y2="204" stroke={accent} stroke-width="5" stroke-linecap="round" />
        <line x1="208" y1="128" x2="214" y2="204" stroke={accent} stroke-width="5" stroke-linecap="round" />

        <!-- traffic cone -->
        <g>
          <rect x="118" y="196" width="64" height="10" rx="3" fill="#EA8A1E" />
          <polygon points="150,44 178,196 122,196" fill="#F59E0B" />
          <polygon points="139,132 161,132 168,158 132,158" fill="#fff" />
          <polygon points="144,88 156,88 160,106 140,106" fill="#fff" />
        </g>
      </g>

      <!-- gear accents, tying back to the brand mark — slowly rotating -->
      <g transform="translate(228 44)" opacity="0.9">
        <g class="spin-slow">
          <circle r="18" fill="none" stroke={accent} stroke-width="3" />
          <circle r="6" fill="none" stroke={accent} stroke-width="3" />
          <g stroke={accent} stroke-width="3">
            <line x1="0" y1="-22" x2="0" y2="-16" />
            <line x1="0" y1="16" x2="0" y2="22" />
            <line x1="-22" y1="0" x2="-16" y2="0" />
            <line x1="16" y1="0" x2="22" y2="0" />
            <line x1="-15.5" y1="-15.5" x2="-11.3" y2="-11.3" />
            <line x1="11.3" y1="11.3" x2="15.5" y2="15.5" />
            <line x1="-15.5" y1="15.5" x2="-11.3" y2="11.3" />
            <line x1="11.3" y1="-11.3" x2="15.5" y2="-15.5" />
          </g>
        </g>
      </g>
      <g transform="translate(58 56)" opacity="0.6">
        <circle r="10" fill="none" stroke={accent} stroke-width="2.5" />
        <circle r="3.5" fill="none" stroke={accent} stroke-width="2.5" />
      </g>
    </svg>

    <!-- Message -->
    <div class="mb-12">
      <h1 class="font-bold tracking-tight leading-tight text-[#0B1220]" style="font-size: clamp(24px, 4vw, 34px);">
        {heading}
      </h1>
      <p class="mt-3 font-medium tracking-wide" style={`color:${accent}; font-size: 18px;`}>
        {subheading}
      </p>
    </div>

    <!-- Navigation Button -->
    <div>
      <a
        href="/"
        class="inline-block font-medium text-white transition hover:brightness-110 active:translate-y-px"
        style={`background:${accent}; font-size: 16px; padding: 14px 40px; border-radius: 20px;`}
      >
        Back to Homepage
      </a>
    </div>
  </div>
</section>

<style>
  .float-group {
    animation: float 3.5s ease-in-out infinite;
  }
  .spin-slow {
    transform-box: fill-box;
    transform-origin: center;
    animation: spin 12s linear infinite;
  }
  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .float-group,
    .spin-slow {
      animation: none;
    }
  }
</style>
