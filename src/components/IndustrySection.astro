<section id="industries" class="scroll-mt-16 py-8 sm:py-10 bg-[#F9FBFE]">
  <div class="max-w-screen-2xl px-6 sm:px-10 lg:px-16 xl:px-20 mx-auto w-full">
    <p class="text-center !text-[12.6px] tracking-[0.15em] text-[#2563EB] uppercase font-medium mb-6">
      Industries We Empower
    </p>

    <div class="flex flex-wrap lg:flex-nowrap items-stretch justify-center gap-3">
      {
        industries.map((industry) => (
          <div class="flex flex-col items-center text-center gap-2 p-3 w-[104px] sm:w-[110px] shrink-0 bg-white border border-[#DBDBDA] rounded-[14px]">
            <div class="w-9 h-9 rounded-full border border-[#2563EB]/40 flex items-center justify-center text-[#2563EB]">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d={industry.path} />
              </svg>
            </div>
            <span class="!text-[11.5px] text-black leading-tight">{industry.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
