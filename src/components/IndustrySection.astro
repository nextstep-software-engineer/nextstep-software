---
// Industries We Empower — icon grid of verticals served
// Icons: Tabler Icons (MIT) via the Iconify API — see README.md for credits.
const industries = [
  {
    label: "Aerospace Engineering",
    paths: [
      "M16 10h4a2 2 0 0 1 0 4h-4l-4 7H9l2-7H7l-2 2H2l2-4l-2-4h3l2 2h4L9 3h3z",
    ],
  },
  {
    label: "Automotive",
    paths: [
      "M5 17a2 2 0 1 0 4 0a2 2 0 1 0-4 0m10 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0",
      "M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2m-4 0H9m-6-6h15m-6 0V6",
    ],
  },
  {
    label: "Healthcare",
    paths: [
      "M12.462 20.87q-.23.07-.462.13A12 12 0 0 1 3.5 6A12 12 0 0 0 12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 .11 6.37M16 19h6m-3-3v6",
    ],
  },
  {
    label: "Financial Services",
    paths: ["M3 21h18M3 10h18M5 6l7-3l7 3M4 10v11m16-11v11M8 14v3m4-3v3m4-3v3"],
  },
  {
    label: "Energy & Utilities",
    paths: ["M13 3v7h6l-8 11v-7H5z"],
  },
  {
    label: "Retail & E-commerce",
    paths: [
      "M4 19a2 2 0 1 0 4 0a2 2 0 1 0-4 0m11 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0",
      "M17 17H6V3H4",
      "m6 5l14 1l-1 7H6",
    ],
  },
  {
    label: "Logistics & Supply Chain",
    paths: [
      "M5 17a2 2 0 1 0 4 0a2 2 0 1 0-4 0m10 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0",
      "M5 17H3v-4M2 5h11v12m-4 0h6m4 0h2v-6h-8m0-5h5l3 5M3 9h4",
    ],
  },
  {
    label: "Government",
    paths: [
      "M3 21h7v-3a2 2 0 0 1 4 0v3h7M6 21v-9m12 9v-9M6 12h12a3 3 0 0 0 3-3a9 8 0 0 1-9-6a9 8 0 0 1-9 6a3 3 0 0 0 3 3",
    ],
  },
  {
    label: "Compliance & Security",
    paths: [
      "M12 3l8 4v5c0 5-3.5 7.5-8 9c-4.5-1.5-8-4-8-9V7z",
      "M10 13v-2a2 2 0 1 1 4 0v2M9 13h6v4H9z",
    ],
  },
  {
    label: "And Many More",
    paths: [
      "M4 12a1 1 0 1 0 2 0a1 1 0 1 0-2 0m7 0a1 1 0 1 0 2 0a1 1 0 1 0-2 0m7 0a1 1 0 1 0 2 0a1 1 0 1 0-2 0",
    ],
  },
];
---

<section id="industries" class="scroll-mt-16 py-8 sm:py-10 bg-[#F9FBFE] overflow-x-hidden">
  <p class="text-center !text-[12.6px] tracking-[0.15em] text-[#2563EB] uppercase font-medium mb-6 px-6">
    Industries We Empower
  </p>

  <!-- Full-bleed scroll track: on wide screens where all 10 cards fit, they're
       centered; on narrower screens it scrolls edge-to-edge across the full
       viewport width instead of being boxed in by the page's max-width. -->
  <div class="w-full overflow-x-auto">
    <div class="flex items-stretch justify-center gap-2 w-max mx-auto px-4 pb-1">
      {
        industries.map((industry) => (
          <div class="flex flex-col items-center text-center gap-2 p-3 w-[130px] shrink-0 bg-white border border-[#DBDBDA] rounded-[14px]">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.4" class="w-12 h-12">
              {industry.paths.map((d) => (
                <path stroke-linecap="round" stroke-linejoin="round" d={d} />
              ))}
            </svg>
            <span class="w-full !text-[10.5px] font-semibold text-black leading-tight">{industry.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
