---
// Our Team Section — leadership grid
// Replace name / role / bio / image below with real team details.
// Set `image` to a photo path (e.g. "/team/jane-doe.webp") to swap in a
// real headshot; leave it empty to keep the placeholder avatar.

// Single accent color, matching the blue used site-wide (WhatWeDo, TrustBar, etc.)
const accent = "#2563EB";
const tint = "#EAF0FE";

const team = [
  {
    name: "Add Name",
    role: "Chief Executive Officer",
    bio: "Leads company strategy and long-term vision.",
    image: "",
    accent,
    tint,
  },
  {
    name: "Add Name",
    role: "VP of Engineering",
    bio: "Owns platform architecture and technical direction.",
    image: "",
    accent,
    tint,
  },
  {
    name: "Add Name",
    role: "VP of Infrastructure",
    bio: "Drives cloud, DevOps, and reliability practices.",
    image: "",
    accent,
    tint,
  },
  {
    name: "Add Name",
    role: "Chief Operating Officer",
    bio: "Runs day-to-day operations and client delivery.",
    image: "",
    accent,
    tint,
  },
  {
    name: "Add Name",
    role: "Head of Delivery",
    bio: "Keeps client engagements on track from kickoff to launch.",
    image: "",
    accent,
    tint,
  },
];
---

<section id="our-team" class="relative py-16 sm:py-20 lg:py-24 bg-[#151824] overflow-hidden">
  <!-- Soft decorative glow for depth, matching the site's blue accent -->
  <div
    class="absolute -top-24 -right-24 w-[420px] h-[420px] rounded-full bg-[#2563EB]/[0.1] blur-3xl pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 max-w-screen-xl px-4 sm:px-6 lg:px-8 mx-auto w-full">
    <div class="mb-14 sm:mb-16 text-center">
      <h2 class="!text-[24.5px] text-white">Our Team</h2>
      <p class="mt-4 !text-[15.4px] text-white/70 max-w-xl mx-auto">
        The people driving engineering excellence at every step.
      </p>
    </div>

    <div class="relative">
      <!-- Edge fade hints that the row scrolls (mobile only) -->
      <div
        class="absolute inset-y-0 right-0 w-4 bg-gradient-to-l from-[#151824] to-transparent z-10 pointer-events-none sm:hidden"
        aria-hidden="true"
      >
      </div>

      <div class="team-scroll flex sm:flex-wrap sm:justify-center gap-x-8 gap-y-14 overflow-x-auto sm:overflow-visible snap-x snap-mandatory sm:snap-none scroll-pl-4 scroll-pr-4 pl-4 pr-4 sm:px-0 pb-2 sm:pb-0">
      {
        team.map((member) => (
          <div class="text-center shrink-0 w-[calc(50%_-_1rem)] sm:w-[190px] snap-start">
            <div
              class="w-20 h-20 sm:w-24 sm:h-24 rounded-full overflow-hidden mx-auto flex items-center justify-center"
              style={!member.image ? `background:${member.tint}` : ""}
            >
              {member.image ? (
                <img
                  src={member.image}
                  alt={member.name}
                  class="w-full h-full object-cover"
                />
              ) : (
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  class="w-9 h-9"
                  style={`color:${member.accent}`}
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
                  />
                </svg>
              )}
            </div>

            <h3 class="mt-4 !text-[14px] text-white">{member.name}</h3>
            <p class="mt-1 !text-[12px] font-medium text-[#8FB3FA]">
              {member.role}
            </p>
            <p class="mt-2.5 !text-[12.6px] text-white/60 leading-relaxed">
              {member.bio}
            </p>
          </div>
        ))
      }
      </div>
    </div>
  </div>
</section>

<style>
  .team-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .team-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
