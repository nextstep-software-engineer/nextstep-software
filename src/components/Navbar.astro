---
// Props (optional): links, logoSrc, theme ("dark" | "light")
const { pathname } = Astro.url;

const links: { href: string; label: string; dropdown?: boolean }[] = Astro.props.links ?? [
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/insights", label: "Insights" },
  { href: "/careers", label: "Careers" },
];

const logoSrc = Astro.props.logoSrc ?? "/logo-nextstep.svg";

const ctaHref = Astro.props.ctaHref ?? "/#contact";
const ctaLabel = Astro.props.ctaLabel ?? "Contact";

// "dark" = navy bg / white text (matches a dark hero, e.g. Approach page).
// "light" = white bg / navy text (matches a light hero, e.g. Home page).
const theme = Astro.props.theme === "light" ? "light" : "dark";
const isLight = theme === "light";
---

<style is:global>
  @media (min-width: 1024px) {
    .ns-nav {
      grid-template-columns: 1fr auto 1fr;
    }
  }
</style>

<header
  class:list={[
    "sticky top-0 z-[9999]",
    isLight ? "bg-[#F9FBFE] text-[#0B1220]" : "bg-[#151824] text-white",
  ]}
>
  <nav
    class="ns-nav mx-auto max-w-screen-2xl flex items-center justify-between px-4 sm:px-6 lg:px-8 h-20 lg:h-24"
    aria-label="Main"
  >
    <!-- Left: Logo -->
    <a
      href="/"
      class="inline-flex items-center gap-3 w-fit"
      aria-label="Nextstep — Home"
    >
      <img
        src={logoSrc}
        alt="NEXTSTEP logo"
        class:list={[
          "w-[150px] h-[59px] sm:w-[175px] sm:h-[69px] lg:w-[203px] lg:h-[80px]",
          isLight && "brightness-0",
        ]}
        loading="eager"
        decoding="async"
      />
      <span class="sr-only">Nextstep Engineering Software Solutions</span>
    </a>

    <!-- Right: Links + CTA + Mobile menu -->
    <div class="ml-auto flex items-center gap-8">
      <!-- Links (hidden on mobile) -->
      <ul class="hidden lg:flex items-center gap-5 xl:gap-7 relative">
        {
          links.map(({ href, label, dropdown }) => {
            const active =
              href === "/" ? pathname === "/" : pathname.startsWith(href);
            return (
              <li>
                <a
                  href={href}
                  data-ns-link
                  data-active={active ? "true" : "false"}
                  data-active-class={isLight ? "text-[#2563EB]" : "text-white"}
                  data-inactive-class={isLight ? "text-[#0B1220]/70" : "text-white/85"}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "relative inline-flex items-center gap-1 !text-[16px] font-['Manrope'] font-bold tracking-wide transition-colors whitespace-nowrap",
                    "focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-400/60 rounded-md",
                    isLight
                      ? ["hover:text-[#0B1220]", active ? "text-[#2563EB]" : "text-[#0B1220]/70"]
                      : ["hover:text-white", active ? "text-white" : "text-white/85"],
                  ]}
                >
                  {label}
                  {dropdown && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3 h-3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  )}
                </a>
              </li>
            );
          })
        }
        <!-- Single sliding underline, repositioned via JS to sit under whichever link is active -->
        <span
          id="ns-underline-bar"
          class:list={[
            "absolute -bottom-3 h-[2px] rounded-full pointer-events-none opacity-0",
            isLight ? "bg-[#2563EB]" : "bg-[#8FB3FA]",
          ]}
        />
      </ul>

      <!-- CTA button (hidden on mobile, shown in mobile sheet instead) -->
      <a
        href={ctaHref}
        class="hidden lg:inline-flex items-center justify-center px-5 py-2 !text-[16px] font-medium text-white bg-[#2563EB] rounded-xl hover:bg-[#1d4fd1] transition-colors"
      >
        {ctaLabel}
      </a>

      <!-- Hamburger (only visible on mobile) -->
      <button
        id="ns-menu-button"
        class:list={[
          "lg:hidden inline-flex h-9 w-9 items-center justify-center rounded-md",
          "focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-400/70",
          isLight
            ? "border border-black/10 bg-black/5 hover:bg-black/10"
            : "border border-white/10 bg-white/5 hover:bg-white/10",
        ]}
        aria-label="Open menu"
        aria-controls="ns-mobile-menu"
        aria-expanded="false"
      >
        <svg
          viewBox="0 0 24 24"
          class="h-5 w-5"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            id="ns-menu-icon-open"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 7h16M4 12h16M4 17h16"></path>
          <path
            id="ns-menu-icon-close"
            class="hidden"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile sheet -->
  <div
    id="ns-mobile-menu"
    class:list={[
      "lg:hidden hidden px-4 sm:px-6",
      isLight ? "border-t border-[#EDEDED] bg-[#F9FBFE]" : "border-t border-white/10 bg-[#151922]",
    ]}
  >
    <ul class="py-3 space-y-1">
      {
        links.map(({ href, label }) => {
          const active =
            href === "/" ? pathname === "/" : pathname.startsWith(href);
          return (
            <li>
              <a
                href={href}
                class:list={[
                  "block rounded-md px-2 py-2 text-[16px] font-['Manrope'] font-bold",
                  "focus:outline-none",
                  isLight
                    ? [
                        "text-[#0B1220]/80 hover:bg-black/5 focus:bg-black/5",
                        active && "text-[#2563EB]",
                      ]
                    : [
                        "text-white/90 hover:bg-white/5 focus:bg-white/5",
                        active && "text-white",
                      ],
                ]}
              >
                {label}
              </a>
            </li>
          );
        })
      }
      <li class="pt-2">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center w-full px-5 py-2.5 !text-[16px] font-medium text-white bg-[#2563EB] rounded-xl hover:bg-[#1d4fd1] transition-colors"
        >
          {ctaLabel}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Tiny, framework-free toggler with accessibility niceties
  const btn = document.getElementById("ns-menu-button");
  const menu = document.getElementById("ns-mobile-menu");
  const openIcon = document.getElementById("ns-menu-icon-open");
  const closeIcon = document.getElementById("ns-menu-icon-close");
  if (btn && menu) {
    const close = () => {
      menu.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Open menu");
      openIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    };
    const open = () => {
      menu.classList.remove("hidden");
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", "Close menu");
      openIcon?.classList.add("hidden");
      closeIcon?.classList.remove("hidden");
    };
    const toggle = () => (menu.classList.contains("hidden") ? open() : close());

    btn.addEventListener("click", toggle);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
    // Close when clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as Node | null;

      if (target && !menu.contains(target) && !btn.contains(target)) {
        close();
      }
    });
  }

  // Move the active-link underline to whichever link was just clicked,
  // instead of waiting for the next page load to resolve it. A single bar
  // slides between links (via left/width) rather than each link owning its
  // own underline, so the change reads as motion instead of a jump-cut.
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-ns-link]");
  const bar = document.getElementById("ns-underline-bar");
  const previousNavKey = "ns-previous-nav-href";

  const placeBar = (link: HTMLAnchorElement, animate: boolean) => {
    if (!bar) return;
    bar.style.transition = animate ? "left 0.25s ease, width 0.25s ease, opacity 0.25s ease" : "none";
    bar.style.left = `${link.offsetLeft}px`;
    bar.style.width = `${link.offsetWidth}px`;
    bar.style.opacity = "1";
  };

  const initialActive = Array.from(navLinks).find((l) => l.dataset.active === "true");
  if (initialActive) {
    let previousHref: string | null = null;
    try {
      previousHref = sessionStorage.getItem(previousNavKey);
      sessionStorage.removeItem(previousNavKey);
    } catch (_) {}

    const previousLink = previousHref
      ? Array.from(navLinks).find((link) => {
          try {
            return new URL(link.href).pathname === new URL(previousHref, window.location.origin).pathname;
          } catch (_) {
            return false;
          }
        })
      : undefined;

    if (previousLink && previousLink !== initialActive) {
      // Start at the active item from the page we just left, then slide to
      // this page's active item. This also covers navigation initiated by
      // cards, buttons, logos, footer links, and other non-navbar controls.
      requestAnimationFrame(() => {
        placeBar(previousLink, false);
        requestAnimationFrame(() => placeBar(initialActive, true));
      });
    } else {
      // Direct page load, refresh, or same active section.
      requestAnimationFrame(() => placeBar(initialActive, false));
    }
  }

  // Remember the current navbar position before any normal internal
  // cross-page navigation, even when the clicked link is outside the navbar.
  document.addEventListener(
    "click",
    (event) => {
      if (
        event.defaultPrevented ||
        event.button !== 0 ||
        event.metaKey ||
        event.ctrlKey ||
        event.shiftKey ||
        event.altKey
      ) return;

      const target = event.target;
      const anchor = target instanceof Element
        ? target.closest<HTMLAnchorElement>("a[href]")
        : null;
      if (!anchor || anchor.target === "_blank" || anchor.hasAttribute("download")) return;

      try {
        const destination = new URL(anchor.href, window.location.href);
        if (
          destination.origin !== window.location.origin ||
          destination.pathname === window.location.pathname
        ) return;

        const currentActive = Array.from(navLinks).find(
          (link) => link.dataset.active === "true",
        );
        if (currentActive) {
          sessionStorage.setItem(previousNavKey, currentActive.getAttribute("href") ?? "/");
        }
      } catch (_) {}
    },
    true,
  );

  navLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      // Navbar links already animate before navigation. Clear the cross-page
      // handoff recorded by the document-level listener so the destination
      // page does not replay the same movement a second time.
      try {
        sessionStorage.removeItem(previousNavKey);
      } catch (_) {}

      placeBar(link, true);
      navLinks.forEach((other) => {
        const activeClass = other.dataset.activeClass ?? "";
        const inactiveClass = other.dataset.inactiveClass ?? "";
        const isClicked = other === link;

        activeClass.split(" ").forEach((c) => c && other.classList.toggle(c, isClicked));
        inactiveClass.split(" ").forEach((c) => c && other.classList.toggle(c, !isClicked));
        other.dataset.active = isClicked ? "true" : "false";
      });

      // Cross-page links (different pathname) would otherwise cut the slide
      // animation short — the browser starts unloading before the 0.25s CSS
      // transition can play, which reads as a teleport. Give it a moment to
      // finish before navigating. Same-page hash links, new-tab, and
      // modifier-clicks are left to behave natively.
      const href = link.getAttribute("href") ?? "";
      const isModifiedClick = e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0;
      const targetPathname = href.split("#")[0];
      const isCrossPage = targetPathname !== "" && targetPathname !== window.location.pathname;

      if (!isModifiedClick && isCrossPage && link.target !== "_blank") {
        e.preventDefault();
        setTimeout(() => {
          window.location.href = href;
        }, 220);
      }
    });
  });
</script>
