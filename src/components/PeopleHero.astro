---
// People Hero — dark theme, matches People.png. Circular tech-ring graphic
// is cropped directly from the mockup banner and used as a background image.
---

<section class="relative bg-[#000714] py-6 sm:py-7 lg:py-8 overflow-hidden">
  <div class="relative z-10 max-w-screen-2xl px-6 sm:px-10 lg:px-16 xl:px-20 mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-12 items-center">
      <!-- Left Content -->
      <div class="flex flex-col gap-6 text-center lg:text-left">
        <p class="!text-[14px] tracking-[0.15em] text-[#2563EB] uppercase font-medium">
          Our People
        </p>

        <h1 class="!text-[34px] sm:!text-[40px] lg:!text-[46px] xl:!text-[52px] leading-[1.1] text-white">
          The People Behind<br />
          <span class="text-[#2563EB]">Every Success.</span>
        </h1>
        <div class="w-[57px] h-[3px] bg-[#2563EB] mx-auto lg:mx-0 -mt-4"></div>

        <p class="!text-[18px] text-white/90 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Engineering excellence starts with exceptional people.
        </p>
        <p class="!text-[16px] text-white/80 max-w-xl mx-auto lg:mx-0 leading-[1.8] -mt-3">
          At NextStep Engineering, our strength lies in the experience, integrity
          and collaborative leadership of our team. Our senior leadership brings
          together decades of expertise across engineering, digital transformation,
          manufacturing, operations and business strategy.
        </p>
        <p class="!text-[16px] text-white/80 max-w-xl mx-auto lg:mx-0 leading-[1.8] -mt-3">
          Together, we work alongside our clients to solve complex challenges,
          deliver measurable outcomes and build long-term partnerships.
        </p>
      </div>

      <!-- Right: concentric tech-ring graphic, cropped from the mockup banner.
           Section bg-color is matched to the image's own background so there's
           no visible seam around it. -->
      <div
        class="mx-auto w-full max-w-[640px] aspect-[456/328] bg-contain bg-center bg-no-repeat"
        style="background-image: url('/people-hero-banner.webp');"
        role="img"
        aria-label="NextStep logo mark inside decorative tech rings"
      >
      </div>
    </div>
  </div>
</section>
