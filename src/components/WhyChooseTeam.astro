          <div class="flex flex-col items-center text-center gap-3 px-4 py-6 border border-[#EDEDED] rounded-[14px]">
            <svg viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.6" class="w-12 h-12">
              {reason.paths.map((d) => (
                <path stroke-linecap="round" stroke-linejoin="round" d={d} />
              ))}
            </svg>
            <h3 class="!text-[15px] text-[#0B1220] leading-snug">{reason.title}</h3>
            <p class="!text-[13.5px] font-medium text-[#374151] leading-relaxed">{reason.description}</p>
